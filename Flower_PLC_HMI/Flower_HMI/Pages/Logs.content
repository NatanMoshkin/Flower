  <div id="LogRow_8" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="452" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[8]%/s%" data-tchmi-rownumber="9"></div>
  <div id="LogRow_9" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="476" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[9]%/s%" data-tchmi-rownumber="10"></div>
  <div id="LogRow_10" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="500" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[10]%/s%" data-tchmi-rownumber="11"></div>
  <div id="LogRow_11" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="524" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[11]%/s%" data-tchmi-rownumber="12"></div>
  <div id="LogRow_12" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="548" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[12]%/s%" data-tchmi-rownumber="13"></div>
  <div id="LogRow_13" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="572" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[13]%/s%" data-tchmi-rownumber="14"></div>
  <div id="LogRow_14" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="596" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[14]%/s%" data-tchmi-rownumber="15"></div>
  <div id="LogRow_15" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="620" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[15]%/s%" data-tchmi-rownumber="16"></div>
  <div id="LogRow_16" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="644" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[16]%/s%" data-tchmi-rownumber="17"></div>
  <div id="LogRow_17" data-tchmi-type="TcHmi.Controls.System.TcHmiUserControlHost" data-tchmi-target-user-control="UserControls/UC_LogRow.usercontrol" data-tchmi-top="668" data-tchmi-top-unit="px" data-tchmi-left="20" data-tchmi-left-unit="px" data-tchmi-width="1400" data-tchmi-width-unit="px" data-tchmi-height="22" data-tchmi-height-unit="px" data-tchmi-entry="%s%ADS.PLC1.GVL_Log.aRecent[17]%/s%" data-tchmi-rownumber="18"></div>
