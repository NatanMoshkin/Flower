       data-tchmi-top="370" data-tchmi-top-unit="px"
       data-tchmi-left="20" data-tchmi-left-unit="px"
       data-tchmi-width="337" data-tchmi-width-unit="px"
       data-tchmi-height="340" data-tchmi-height-unit="px"
       data-tchmi-piston="%s%ADS.PLC1.GVL_HMI.stPushSol1%/s%">
  </div>
</div>
