<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_MasterAutoCycle" Id="{6b4ee376-0a0c-47a5-84cf-72c0a19ed5f4}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MasterAutoCycle
(* Full-machine coordinated auto sequence spanning the robot and the 3
   pairs of SepSol / PushSol pistons (pair count fixed at 3 for this
   machine).

   Simplified robot interface (2026-07-10, per docs/robot-integration-options.md
   Option 1). Two signals cross the boundary, both level (not pulsed):

     Robot -> PLC   stRobot.bStartAssembly     (robot's STAND_SEQ_DO)
     PLC -> Robot   stRobot.bAssemblyRunning   (robot's STAND_SEQ_DI)

   The cycle starts on the rising edge of bStartAssembly. bAssemblyRunning
   is TRUE in every non-IDLE state (including ERR, so the robot times out
   on PLC fault) and FALSE in IDLE.

   Sequence (all 3 pairs move in parallel):

     IDLE                    START button OR bStartAssembly rising OR SimIdle
                             OR bContinuous checked (level - keeps re-arming)
     SEP_EXTENDING           drive SepCmdExtend[1..3]; wait AND of all SepIsExtended
     PUSH_EXTENDING          drive PushCmdExtend[1..3]; wait AND of all PushIsExtended
     DWELL_PUSH              hold both extended; wait tDwellPushMs
     PUSH_RETRACTING         drive PushCmdRetract[1..3]; wait AND of all PushIsRetracted
     PUSH_RETRACTED_DWELL    wait tPushRetractedDwellMs
     SEP_RETRACTING          drive SepCmdRetract[1..3]; wait AND of all SepIsRetracted
     SEP_RETRACTED_DWELL     wait tSepRetractedDwellMs -> IDLE
     ERR                     latched; iErrorCode set to step code; bContinuous
                             cleared so RESET does not restart motion.
                             Reset on HMI RESET rising edge.

   Error codes:
     0  = OK
     1  = SEP_EXTENDING timed out
     3  = PUSH_EXTENDING timed out
     4  = PUSH_RETRACTING timed out
     5  = SEP_RETRACTING timed out
    99  = Operator STOP while running

   The former WAIT_POS2 state (error code 2) is retired: the robot code
   (src0.lua PerformStandSequence) already moves the arm clear of the
   stand BEFORE raising STAND_SEQ_DO, so the PLC does not need a separate
   "robot moved away" wait between SEP_EXTENDING and PUSH_EXTENDING. The
   E_MasterAutoStep.WAIT_POS2 enum value and stHmi.bSimStep_WaitPos2 flag
   remain declared but are unused; safe to remove once the HMI is cleaned.

   Per-step Sim flags on stHmi (bSimStep_Idle, bSimStep_SepExt, and so on)
   let a bench operator advance any waiting step without physical sensors.
   Rising-edge triggered; the FB auto-clears the flag after consumption.

   Sensorless mode (stCfg.bNoSensors): the 4 movement states ignore sensor
   feedback and advance when tStepTimeoutMs expires — the timeout doubles
   as the fixed step duration. Error codes 1/3/4/5 cannot occur while
   sensorless. *)
VAR_INPUT
    (* Robot trigger (level flag from GVL_Robot.stRobot.bStartAssembly;
       driven by the robot's STAND_SEQ_DO through a PLC DI channel). *)
    bStartAssembly        : BOOL;

    (* Per-pair sensor state. MAIN wires each element from stSepSolK/stPushSolK.bIs*. *)
    bSepIsExtended        : ARRAY[1..3] OF BOOL;
    bSepIsRetracted       : ARRAY[1..3] OF BOOL;
    bPushIsExtended       : ARRAY[1..3] OF BOOL;
    bPushIsRetracted      : ARRAY[1..3] OF BOOL;
END_VAR

VAR_IN_OUT
    stHmi     : ST_HmiMasterAuto;
    stCfg     : ST_HmiMasterAutoCfg;
    stRobot   : ST_HmiRobot;
END_VAR

VAR_OUTPUT
    (* MAIN OR-merges these with the per-piston auto FBs. *)
    bSepCmdExtend         : ARRAY[1..3] OF BOOL;
    bSepCmdRetract        : ARRAY[1..3] OF BOOL;
    bPushCmdExtend        : ARRAY[1..3] OF BOOL;
    bPushCmdRetract       : ARRAY[1..3] OF BOOL;

    (* TRUE while the master cycle is in any state other than IDLE or ERR.
       MAIN reads this to force enabled pistons' stHmi.eMode := Automatic
       while running, so bAutoCmd* actually reaches the piston coil (in
       Manual mode the piston FB ignores bAutoCmd*)
    bAnyRunning           : BOOL;
END_VAR

VAR
    (* Rising-edge detectors for momentary HMI buttons + robot start signal. *)
    fbTrigStart           : R_TRIG;
    fbTrigStop            : R_TRIG;
    fbTrigReset           : R_TRIG;
    fbTrigStartAssembly   : R_TRIG;

    (* Rising-edge detectors for per-step Sim flags. *)
    fbSim_Idle            : R_TRIG;
    fbSim_SepExt          : R_TRIG;
    fbSim_PushExt         : R_TRIG;
    fbSim_DwellPush       : R_TRIG;
    fbSim_PushRet         : R_TRIG;
    fbSim_PushRetDwell    : R_TRIG;
    fbSim_SepRet          : R_TRIG;
    fbSim_SepRetDwell     : R_TRIG;

    (* Per-step timer. Same TON, different PT depending on state. On DWELL
       states PT is the dwell; on wait states PT is the timeout. *)
    tonStep               : TON;
    ePrevStep             : E_MasterAutoStep;   (* transition detect for timer reset *)

    (* Loop index *)
    i                     : USINT;

    (* Aggregate sensor flags, computed each cycle in Section 1. *)
    bAllSepExtended       : BOOL;
    bAllSepRetracted      : BOOL;
    bAllPushExtended      : BOOL;
    bAllPushRetracted     : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ==========================================
   0a. RISING-EDGE DETECTORS
   ========================================== *)
fbTrigStart        (CLK := stHmi.bStart);
fbTrigStop         (CLK := stHmi.bStop);
fbTrigReset        (CLK := stHmi.bReset);
fbTrigStartAssembly(CLK := stRobot.bStartAssembly OR stHmi.bSimStartAssembly);

fbSim_Idle        (CLK := stHmi.bSimStep_Idle);
fbSim_SepExt      (CLK := stHmi.bSimStep_SepExt);
fbSim_PushExt     (CLK := stHmi.bSimStep_PushExt);
fbSim_DwellPush   (CLK := stHmi.bSimStep_DwellPush);
fbSim_PushRet     (CLK := stHmi.bSimStep_PushRet);
fbSim_PushRetDwell(CLK := stHmi.bSimStep_PushRetDwell);
fbSim_SepRet      (CLK := stHmi.bSimStep_SepRet);
fbSim_SepRetDwell (CLK := stHmi.bSimStep_SepRetDwell);

(* ==========================================
   0b. AUTO-CLEAR ONE-SHOT FLAGS ON RISING EDGE
   HMI button flags and Sim flags are momentary; after we detect the
   rising edge we clear the raw flag so the operator's next click can
   fire again. stRobot.bStartAssembly is a level flag driven by the
   robot's STAND_SEQ_DO through a physical DI channel; we only consume
   its rising edge and never clear it (the robot owns the level).
   ========================================== *)
IF fbTrigStart.Q  THEN stHmi.bStart := FALSE; END_IF;
IF fbTrigStop.Q   THEN stHmi.bStop  := FALSE; END_IF;
IF fbTrigReset.Q  THEN stHmi.bReset := FALSE; END_IF;

(* Bench sim of the robot start: clear only the sim flag after the edge is
   consumed; the robot-owned level itself is never written. *)
IF fbTrigStartAssembly.Q THEN stHmi.bSimStartAssembly := FALSE; END_IF;

IF fbSim_Idle.Q         THEN stHmi.bSimStep_Idle         := FALSE; END_IF;
IF fbSim_SepExt.Q       THEN stHmi.bSimStep_SepExt       := FALSE; END_IF;
IF fbSim_PushExt.Q      THEN stHmi.bSimStep_PushExt      := FALSE; END_IF;
IF fbSim_DwellPush.Q    THEN stHmi.bSimStep_DwellPush    := FALSE; END_IF;
IF fbSim_PushRet.Q      THEN stHmi.bSimStep_PushRet      := FALSE; END_IF;
IF fbSim_PushRetDwell.Q THEN stHmi.bSimStep_PushRetDwell := FALSE; END_IF;
IF fbSim_SepRet.Q       THEN stHmi.bSimStep_SepRet       := FALSE; END_IF;
IF fbSim_SepRetDwell.Q  THEN stHmi.bSimStep_SepRetDwell  := FALSE; END_IF;

(* ==========================================
   1. AGGREGATE SENSOR STATE
   ========================================== *)
bAllSepExtended   := bSepIsExtended[1]   AND bSepIsExtended[2]   AND bSepIsExtended[3];
bAllSepRetracted  := bSepIsRetracted[1]  AND bSepIsRetracted[2]  AND bSepIsRetracted[3];
bAllPushExtended  := bPushIsExtended[1]  AND bPushIsExtended[2]  AND bPushIsExtended[3];
bAllPushRetracted := bPushIsRetracted[1] AND bPushIsRetracted[2] AND bPushIsRetracted[3];

(* ==========================================
   2. GLOBAL OVERRIDES — STOP and RESET
   STOP while running latches error 99 and drops to ERR. HMI RESET clears
   the error and returns to IDLE. The robot's own RESET_ALARM (robot DI 10)
   is handled robot-side; the PLC does not receive it in the discrete-IO
   interface. Operator must reset both sides after a fault.
   ========================================== *)
IF fbTrigStop.Q AND stHmi.eStep <> E_MasterAutoStep.IDLE AND stHmi.eStep <> E_MasterAutoStep.ERR THEN
    stHmi.iErrorCode := 99;
    stHmi.sErrorText := 'Operator STOP while running';
    stHmi.eStep      := E_MasterAutoStep.ERR;
    (* Drop Continuous on any ERR entry so RESET does not instantly
       restart motion with the box still checked. *)
    stCfg.bContinuous := FALSE;
END_IF;

IF fbTrigReset.Q AND stHmi.eStep = E_MasterAutoStep.ERR THEN
    stHmi.iErrorCode := 0;
    stHmi.sErrorText := '';
    stHmi.eStep      := E_MasterAutoStep.IDLE;
END_IF;

(* ==========================================
   3. STEP TIMER
   Reset tonStep on any state change. In DWELL states PT is the dwell
   duration and Q rising = "dwell complete, advance". In wait states PT
   is the timeout and Q rising = "timed out, error". Non-waiting states
   (IDLE, ERR) do not consult Q.
   ========================================== *)
IF stHmi.eStep <> ePrevStep THEN
    tonStep(IN := FALSE, PT := T#0MS);   // pulse-off resets ET to 0
    ePrevStep := stHmi.eStep;
END_IF;

(* PT depends on state. Wait states use tStepTimeoutMs; dwell states use their own. *)
CASE stHmi.eStep OF
    E_MasterAutoStep.DWELL_PUSH:
        tonStep(IN := TRUE, PT := UDINT_TO_TIME(stCfg.tDwellPushMs));
    E_MasterAutoStep.PUSH_RETRACTED_DWELL:
        tonStep(IN := TRUE, PT := UDINT_TO_TIME(stCfg.tPushRetractedDwellMs));
    E_MasterAutoStep.SEP_RETRACTED_DWELL:
        tonStep(IN := TRUE, PT := UDINT_TO_TIME(stCfg.tSepRetractedDwellMs));
    E_MasterAutoStep.SEP_EXTENDING,
    E_MasterAutoStep.PUSH_EXTENDING,
    E_MasterAutoStep.PUSH_RETRACTING,
    E_MasterAutoStep.SEP_RETRACTING:
        tonStep(IN := TRUE, PT := UDINT_TO_TIME(stCfg.tStepTimeoutMs));
ELSE
    tonStep(IN := FALSE, PT := T#0MS);
END_CASE;

stHmi.tElapsedS := DINT_TO_LREAL(TIME_TO_DINT(tonStep.ET)) / 1000.0;

(* ==========================================
   4. STATE MACHINE
   Default: clear all commands each cycle in the ELSE-ish paths so a
   dropped state doesn't leave stale coils driven. Each state re-asserts
   the commands it owns.
   ========================================== *)
CASE stHmi.eStep OF

    E_MasterAutoStep.IDLE:
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := FALSE;
            bSepCmdRetract[i]  := FALSE;
            bPushCmdExtend[i]  := FALSE;
            bPushCmdRetract[i] := FALSE;
        END_FOR;
        (* No active error while in IDLE (unless just about to enter ERR
           via a global override, handled above). *)
        stHmi.iErrorCode := 0;
        stHmi.sErrorText := '';

        IF fbTrigStart.Q OR fbTrigStartAssembly.Q OR fbSim_Idle.Q OR stCfg.bContinuous THEN
            (* Robot side (or operator, or bench sim) has requested a cycle.
               While bContinuous is checked, IDLE starts the next cycle
               immediately — no START / bStartAssembly edge needed.
               bAssemblyRunning goes TRUE immediately via Section 5 mirror. *)
            stHmi.eStep := E_MasterAutoStep.SEP_EXTENDING;
        END_IF;

    E_MasterAutoStep.SEP_EXTENDING:
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]  := TRUE;
            bSepCmdRetract[i] := FALSE;
        END_FOR;

        IF bAllSepExtended OR fbSim_SepExt.Q OR (stCfg.bNoSensors AND tonStep.Q) THEN
            (* Skip the former WAIT_POS2 — the robot has already moved clear
               of the stand before raising bStartAssembly. *)
            stHmi.eStep := E_MasterAutoStep.PUSH_EXTENDING;
        ELSIF tonStep.Q THEN   (* only reachable when NOT bNoSensors *)
            stHmi.iErrorCode := 1;
            stHmi.sErrorText := 'SEP_EXTENDING timed out';
            stHmi.eStep := E_MasterAutoStep.ERR;
            stCfg.bContinuous := FALSE;
        END_IF;

    E_MasterAutoStep.PUSH_EXTENDING:
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := TRUE;   (* hold sep out *)
            bPushCmdExtend[i]  := TRUE;
            bPushCmdRetract[i] := FALSE;
        END_FOR;

        IF bAllPushExtended OR fbSim_PushExt.Q OR (stCfg.bNoSensors AND tonStep.Q) THEN
            stHmi.eStep := E_MasterAutoStep.DWELL_PUSH;
        ELSIF tonStep.Q THEN
            stHmi.iErrorCode := 3;
            stHmi.sErrorText := 'PUSH_EXTENDING timed out';
            stHmi.eStep := E_MasterAutoStep.ERR;
            stCfg.bContinuous := FALSE;
        END_IF;

    E_MasterAutoStep.DWELL_PUSH:
        (* Hold everything out. *)
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]  := TRUE;
            bPushCmdExtend[i] := TRUE;
        END_FOR;

        IF tonStep.Q OR fbSim_DwellPush.Q THEN
            stHmi.eStep := E_MasterAutoStep.PUSH_RETRACTING;
        END_IF;

    E_MasterAutoStep.PUSH_RETRACTING:
        (* Sep still extended, push retract command asserted. *)
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := TRUE;
            bPushCmdExtend[i]  := FALSE;
            bPushCmdRetract[i] := TRUE;
        END_FOR;

        IF bAllPushRetracted OR fbSim_PushRet.Q OR (stCfg.bNoSensors AND tonStep.Q) THEN
            stHmi.eStep := E_MasterAutoStep.PUSH_RETRACTED_DWELL;
        ELSIF tonStep.Q THEN
            stHmi.iErrorCode := 4;
            stHmi.sErrorText := 'PUSH_RETRACTING timed out';
            stHmi.eStep := E_MasterAutoStep.ERR;
            stCfg.bContinuous := FALSE;
        END_IF;

    E_MasterAutoStep.PUSH_RETRACTED_DWELL:
        (* Sep still held extended, push commands cleared. *)
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := TRUE;
            bPushCmdExtend[i]  := FALSE;
            bPushCmdRetract[i] := FALSE;
        END_FOR;

        IF tonStep.Q OR fbSim_PushRetDwell.Q THEN
            stHmi.eStep := E_MasterAutoStep.SEP_RETRACTING;
        END_IF;

    E_MasterAutoStep.SEP_RETRACTING:
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]  := FALSE;
            bSepCmdRetract[i] := TRUE;
        END_FOR;

        IF bAllSepRetracted OR fbSim_SepRet.Q OR (stCfg.bNoSensors AND tonStep.Q) THEN
            stHmi.eStep := E_MasterAutoStep.SEP_RETRACTED_DWELL;
        ELSIF tonStep.Q THEN
            stHmi.iErrorCode := 5;
            stHmi.sErrorText := 'SEP_RETRACTING timed out';
            stHmi.eStep := E_MasterAutoStep.ERR;
            stCfg.bContinuous := FALSE;
        END_IF;

    E_MasterAutoStep.SEP_RETRACTED_DWELL:
        (* Everything home. *)
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := FALSE;
            bSepCmdRetract[i]  := FALSE;
            bPushCmdExtend[i]  := FALSE;
            bPushCmdRetract[i] := FALSE;
        END_FOR;

        IF tonStep.Q OR fbSim_SepRetDwell.Q THEN
            stHmi.nCyclesCompleted := stHmi.nCyclesCompleted + 1;
            (* Back to IDLE. If bContinuous is still checked, IDLE re-arms
               the next cycle by itself on the next scan. *)
            stHmi.eStep := E_MasterAutoStep.IDLE;
        END_IF;

    E_MasterAutoStep.ERR:
        (* Latched. stRobot.bAssemblyRunning stays TRUE while in ERR (see
           Section 5), so the robot times out its own polling wait and
           enters its error handler. Exit only via Section 2 (HMI RESET). *)
        FOR i := 1 TO 3 DO
            bSepCmdExtend[i]   := FALSE;
            bSepCmdRetract[i]  := FALSE;
            bPushCmdExtend[i]  := FALSE;
            bPushCmdRetract[i] := FALSE;
        END_FOR;

ELSE
    (* Defensive: any undefined value snaps to IDLE with no commands. *)
    FOR i := 1 TO 3 DO
        bSepCmdExtend[i]   := FALSE;
        bSepCmdRetract[i]  := FALSE;
        bPushCmdExtend[i]  := FALSE;
        bPushCmdRetract[i] := FALSE;
    END_FOR;
    stHmi.eStep := E_MasterAutoStep.IDLE;
END_CASE;

(* ==========================================
   5. STATUS MIRROR — human-readable step name + running flags
   TO_STRING relies on the enum's {to_string} attribute.
   bAnyRunning is TRUE any time the cycle is actively driving pistons —
   MAIN uses it to force enabled pistons into Automatic mode. False in ERR
   so the operator's manual choice is preserved after a fault.
   stRobot.bAssemblyRunning is the outbound level to the robot — TRUE in
   any non-IDLE state (including ERR, so the robot times out on PLC fault)
   and FALSE only in IDLE.
   ========================================== *)
stHmi.sStepText := TO_STRING(stHmi.eStep);
bAnyRunning     := (stHmi.eStep <> E_MasterAutoStep.IDLE)
               AND (stHmi.eStep <> E_MasterAutoStep.ERR);
stRobot.bAssemblyRunning := (stHmi.eStep <> E_MasterAutoStep.IDLE);
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>