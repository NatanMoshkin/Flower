<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{14abf4a7-7840-47f5-84af-a7dedadf8c83}">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
    fbSepSol1  : FB_SolSpringPiston_2Pos;
    fbSepSol2  : FB_SolSpringPiston_2Pos;
    fbSepSol3  : FB_SolSpringPiston_2Pos;
    fbPushSol1 : FB_SolSpringPiston_2Pos;
    fbPushSol2 : FB_SolSpringPiston_2Pos;
    fbPushSol3 : FB_SolSpringPiston_2Pos;

    // Auto-cycle sequencers. Each drives one piston's bAutoCmdExtend /
    // bAutoCmdRetract pins via its bCmdExtend / bCmdRetract outputs.
    // Extending to more pistons is a copy-paste of the FB instance +
    // one MAIN call block + one HMI symbol pair (stXxxAuto + stXxxAutoCfg).
    fbSepSol1Auto  : FB_PistonAutoCycle;
    fbPushSol1Auto : FB_PistonAutoCycle;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ==========================================
   READ INPUTS — copy raw GVL_IO.dIn[] channels into named GVL_App aliases
   DI convention: each actuator still has both a Retracted and an Extended
   proximity switch (SOL-Spring only removes the retract coil, not the
   retracted-position sensor).
   ==========================================
   OPEN ISSUE: physical DI channels for SepSol2/3 and PushSol2/3 are not
   yet assigned. Their GVL_App sensor aliases stay FALSE until wired, so
   those FBs' HMI position indicators light up only via the operator's
   Simulate checkboxes. The DO side is fully assigned (see WRITE OUTPUTS).
   ========================================== *)
GVL_App.bSensorSepRetracted1  := GVL_IO.dIn[1];
GVL_App.bSensorSepExtended1   := GVL_IO.dIn[2];
// GVL_App.bSensorSepRetracted2  := GVL_IO.dIn[??];   // TODO: assign SepSol2 DI
// GVL_App.bSensorSepExtended2   := GVL_IO.dIn[??];
// GVL_App.bSensorSepRetracted3  := GVL_IO.dIn[??];   // TODO: assign SepSol3 DI
// GVL_App.bSensorSepExtended3   := GVL_IO.dIn[??];
GVL_App.bSensorPushRetracted1 := GVL_IO.dIn[7];
GVL_App.bSensorPushExtended1  := GVL_IO.dIn[8];
// GVL_App.bSensorPushRetracted2 := GVL_IO.dIn[??];   // TODO: assign PushSol2 DI
// GVL_App.bSensorPushExtended2  := GVL_IO.dIn[??];
// GVL_App.bSensorPushRetracted3 := GVL_IO.dIn[??];   // TODO: assign PushSol3 DI
// GVL_App.bSensorPushExtended3  := GVL_IO.dIn[??];

(* ==========================================
   Pin separators (SOL-Spring, 2 limit switches, single Extend coil).
   SepSol1 and PushSol1 are driven by their own FB_PistonAutoCycle
   instances (called first so their outputs feed the piston FB this
   cycle). SepSol2/3 and PushSol2/3 remain manual-only — their
   bAutoCmd* pins stay wired to FALSE until each gets its own
   sequencer instance.
   ========================================== *)
fbSepSol1Auto(
    sName        := 'SepSol1Auto',
    stHmi        := GVL_HMI.stSepSol1,
    stAuto       := GVL_HMI.stSepSol1Auto,
    stCfg        := GVL_HmiPersistent.stSepSol1AutoCfg
    // bCmdExtend / bCmdRetract wired inline in the fbSepSol1 call below
);

fbSepSol1(
    bAutoCmdExtend   := fbSepSol1Auto.bCmdExtend,
    bAutoCmdRetract  := fbSepSol1Auto.bCmdRetract,
    bSwitchExtended  := GVL_App.bSensorSepExtended1,
    bSwitchRetracted := GVL_App.bSensorSepRetracted1,
    stHmi            := GVL_HMI.stSepSol1,
    bOutSolenoid     => GVL_App.bValveSepExtend1
);

fbSepSol2(
    bAutoCmdExtend   := FALSE,
    bAutoCmdRetract  := FALSE,
    bSwitchExtended  := GVL_App.bSensorSepExtended2,
    bSwitchRetracted := GVL_App.bSensorSepRetracted2,
    stHmi            := GVL_HMI.stSepSol2,
    bOutSolenoid     => GVL_App.bValveSepExtend2
);

fbSepSol3(
    bAutoCmdExtend   := FALSE,
    bAutoCmdRetract  := FALSE,
    bSwitchExtended  := GVL_App.bSensorSepExtended3,
    bSwitchRetracted := GVL_App.bSensorSepRetracted3,
    stHmi            := GVL_HMI.stSepSol3,
    bOutSolenoid     => GVL_App.bValveSepExtend3
);

(* ==========================================
   Pin pushers
   ========================================== *)
fbPushSol1Auto(
    sName        := 'PushSol1Auto',
    stHmi        := GVL_HMI.stPushSol1,
    stAuto       := GVL_HMI.stPushSol1Auto,
    stCfg        := GVL_HmiPersistent.stPushSol1AutoCfg
    // bCmdExtend / bCmdRetract wired inline in the fbPushSol1 call below
);

fbPushSol1(
    bAutoCmdExtend   := fbPushSol1Auto.bCmdExtend,
    bAutoCmdRetract  := fbPushSol1Auto.bCmdRetract,
    bSwitchExtended  := GVL_App.bSensorPushExtended1,
    bSwitchRetracted := GVL_App.bSensorPushRetracted1,
    stHmi            := GVL_HMI.stPushSol1,
    bOutSolenoid     => GVL_App.bValvePushExtend1
);

fbPushSol2(
    bAutoCmdExtend   := FALSE,
    bAutoCmdRetract  := FALSE,
    bSwitchExtended  := GVL_App.bSensorPushExtended2,
    bSwitchRetracted := GVL_App.bSensorPushRetracted2,
    stHmi            := GVL_HMI.stPushSol2,
    bOutSolenoid     => GVL_App.bValvePushExtend2
);

fbPushSol3(
    bAutoCmdExtend   := FALSE,
    bAutoCmdRetract  := FALSE,
    bSwitchExtended  := GVL_App.bSensorPushExtended3,
    bSwitchRetracted := GVL_App.bSensorPushRetracted3,
    stHmi            := GVL_HMI.stPushSol3,
    bOutSolenoid     => GVL_App.bValvePushExtend3
);

(* ==========================================
   WRITE OUTPUTS — copy named GVL_App aliases into raw GVL_IO.dOut[] channels
   DO layout: single Extend coil per actuator (SOL-Spring, spring retracts).
     dOut[1..3] = SepSolN Extend
     dOut[4..6] = PushSolN Extend
     dOut[7..8] = free (freed by the SOL-Spring migration — available for reuse)
   ========================================== *)
GVL_IO.dOut[1] := GVL_App.bValveSepExtend1;
GVL_IO.dOut[2] := GVL_App.bValveSepExtend2;
GVL_IO.dOut[3] := GVL_App.bValveSepExtend3;
GVL_IO.dOut[4] := GVL_App.bValvePushExtend1;
GVL_IO.dOut[5] := GVL_App.bValvePushExtend2;
GVL_IO.dOut[6] := GVL_App.bValvePushExtend3;
GVL_IO.dOut[7] := FALSE;   // freed — available for reuse
GVL_IO.dOut[8] := FALSE;   // freed — available for reuse
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
