<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_SolSpringPiston_2Pos" Id="{dbca3142-cfb0-4b0e-af16-d67fa4f955fc}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_SolSpringPiston_2Pos
(* Single-solenoid, spring-return 2-position actuator.
   Coil energised  -> drives to EXTENDED.
   Coil de-energised -> mechanical spring returns to RETRACTED.
   Fail-safe by construction: broken wire, dead coil, PLC power loss
   or e-stop all result in a retract (safe state).

   Interface is kept symmetric with FB_SolSolPiston_2Pos so a sequencer FB
   (e.g. FB_PistonAutoCycle) can drive either actuator type without a
   custom variant. Reuses ST_HmiPiston unchanged; the retract-coil mirror
   field (stHmi.bOutSolenoidRetract) is always FALSE because no retract
   coil exists on this actuator. *)
VAR_INPUT
    (* Automatic Commands from PLC sequence logic. Wired to FALSE in MAIN until FB_Auto exists. *)
    bAutoCmdExtend    : BOOL;
    bAutoCmdRetract   : BOOL;

    (* Physical Feedback (Proximity Switches) *)
    bSwitchExtended   : BOOL;
    bSwitchRetracted  : BOOL;
END_VAR

VAR_IN_OUT
    (* HMI contract — mode, manual + simulate inputs, latched + sensor status *)
    stHmi             : ST_HmiPiston;
END_VAR

VAR_OUTPUT
    (* Physical Output to Solenoid — SINGLE coil.
       TRUE  = coil energised, actuator drives EXTENDED.
       FALSE = coil de-energised, spring returns actuator to RETRACTED. *)
    bOutSolenoid      : BOOL;
END_VAR

VAR
    (* Internal Target States *)
    bTargetExtend     : BOOL;
    bTargetRetract    : BOOL;

    (* HMI Manual-Button Edge Detection *)
    fbTrigManExtend   : R_TRIG;
    fbTrigManRetract  : R_TRIG;

    (* Effective sensor states = real OR HMI simulate. Recomputed every cycle in Section 0a. *)
    bSwitchExtended_eff  : BOOL;
    bSwitchRetracted_eff : BOOL;

    (* Previous-cycle snapshots for the mode-field bridge in Section 0b.
       Classic PLC HMI writes stHmi.bMode (Rotary Switch is boolean-only);
       web HMI writes stHmi.eMode (enum via ToggleSwitch). This FB is the
       authoritative reader of eMode, so we sync in whichever direction
       changed since last cycle. *)
    bPrevMode : BOOL;
    ePrevMode : E_ControlMode;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ==========================================
   0b. MODE-FIELD BRIDGE — sync bMode <-> eMode
   The classic PLC HMI (VISUs) writes stHmi.bMode because its Rotary Switch
   element is boolean-only. The web HMI (Flower_HMI) writes stHmi.eMode via
   a ToggleSwitch. Rest of this FB reads eMode as the authoritative field,
   so we mirror bMode into eMode when the classic HMI toggled the switch,
   and mirror eMode back into bMode when the web HMI (or anyone else) wrote
   eMode. Edge-triggered — whichever side changed since last cycle wins.
   Runs BEFORE Section 0 so downstream logic sees a coherent eMode.
   ========================================== *)
IF stHmi.bMode <> bPrevMode THEN
    // Classic VISU changed bMode → propagate to eMode
    IF stHmi.bMode THEN
        stHmi.eMode := E_ControlMode.Automatic;
    ELSE
        stHmi.eMode := E_ControlMode.Manual;
    END_IF;
ELSIF stHmi.eMode <> ePrevMode THEN
    // Web HMI (or any other writer) changed eMode → propagate to bMode
    stHmi.bMode := (stHmi.eMode = E_ControlMode.Automatic);
END_IF;

bPrevMode := stHmi.bMode;
ePrevMode := stHmi.eMode;

(* ==========================================
   0a. EFFECTIVE SENSOR INPUTS (real OR HMI simulate)
   ========================================== *)
bSwitchExtended_eff  := bSwitchExtended  OR stHmi.bSimulateExtended;
bSwitchRetracted_eff := bSwitchRetracted OR stHmi.bSimulateRetracted;

(* ==========================================
   0. HMI MANUAL BUTTON LATCHING (Radio-Button Behavior)
   ========================================== *)
fbTrigManExtend(CLK := stHmi.bManCmdExtend);
fbTrigManRetract(CLK := stHmi.bManCmdRetract);

// Independent IFs (not ELSIF): if multiple edges fire in the same cycle, the last one wins (Retract > Extend).
IF fbTrigManExtend.Q  THEN stHmi.bSelectedExtend := TRUE;  stHmi.bSelectedRetract := FALSE; END_IF;
IF fbTrigManRetract.Q THEN stHmi.bSelectedExtend := FALSE; stHmi.bSelectedRetract := TRUE;  END_IF;

IF stHmi.eMode = E_ControlMode.Automatic THEN
    stHmi.bSelectedExtend := FALSE; stHmi.bSelectedRetract := FALSE;
END_IF;

(* ==========================================
   1. MODE SELECTION & COMMAND MAPPING
   Spring-return semantics: both bAutoCmd* inputs are accepted for interface
   parity with FB_SolSolPiston_2Pos, but physically only Extend commands the
   coil. If both auto bits are TRUE we treat it as a conflict and de-energise
   (safe default — spring retracts).
   ========================================== *)
IF stHmi.eMode = E_ControlMode.Automatic THEN
    bTargetExtend  := bAutoCmdExtend  AND NOT bAutoCmdRetract;
    bTargetRetract := bAutoCmdRetract AND NOT bAutoCmdExtend;

ELSIF stHmi.eMode = E_ControlMode.Manual THEN
    bTargetExtend  := stHmi.bSelectedExtend;
    bTargetRetract := stHmi.bSelectedRetract;

ELSE
    // Safe default: undefined mode → no targets
    bTargetExtend  := FALSE;
    bTargetRetract := FALSE;
END_IF;

(* ==========================================
   1a. JOG OVERRIDE — clear latched selection while either jog is held
   ========================================== *)
// Section 1 above already copied stHmi.bSelected* into bTarget*. The stale
// bTarget* is harmless because Section 2's jog branches sit ahead of the
// bTarget* branches in the IF/ELSIF ladder and preempt them.
IF stHmi.bManJogExtend OR stHmi.bManJogRetract THEN
    stHmi.bSelectedExtend := FALSE; stHmi.bSelectedRetract := FALSE;
END_IF;

(* ==========================================
   1b. TARGET-REACHED RESET — clear bSelected* once the piston arrives
   ========================================== *)
IF stHmi.bSelectedExtend  AND bSwitchExtended_eff  THEN stHmi.bSelectedExtend  := FALSE; END_IF;
IF stHmi.bSelectedRetract AND bSwitchRetracted_eff THEN stHmi.bSelectedRetract := FALSE; END_IF;

(* ==========================================
   2. SOLENOID CONTROL — single coil, spring-return
   One coil (bOutSolenoid). Retract is achieved by de-energising the coil;
   the mechanical spring returns the actuator. Consequences:
     - No "retract coil" branch — retract IS the ELSE.
     - ELSE unconditionally clears the coil (safe default). Unlike SolSol,
       there is no coil-retain risk that could keep driving after the target
       is reached.
     - No coil-oscillation guards needed — the spring is passive and always
       correct.
   Jog branches sit first and are gated by Manual mode so they cannot
   interfere with the automatic sequence.
   ========================================== *)
// JOG EXTEND: while held in Manual, drive coil until end sensor
IF stHmi.bManJogExtend AND NOT bSwitchExtended_eff AND stHmi.eMode = E_ControlMode.Manual THEN
    bOutSolenoid := TRUE;

// JOG RETRACT: while held in Manual, de-energise coil (spring retracts)
ELSIF stHmi.bManJogRetract AND stHmi.eMode = E_ControlMode.Manual THEN
    bOutSolenoid := FALSE;

// CASE 1: Move to EXTENDED — energise coil until Extended sensor
ELSIF bTargetExtend AND NOT bSwitchExtended_eff THEN
    bOutSolenoid := TRUE;

// CASE 2: Target reached, retract requested, or no active target → de-energise, spring returns
ELSE
    bOutSolenoid := FALSE;
END_IF;

(* ==========================================
   3. HMI STATUS FEEDBACK
   bIsMoving: OR the coil state with "between sensors" so the HMI shows
   motion during the passive spring-return stroke (no coil to sense on that
   half of the cycle). This differs from FB_SolSolPiston_2Pos, where both
   strokes are coil-driven.

   bOutSolenoidRetract is written FALSE unconditionally — no retract coil
   exists on a spring-return actuator, so the mirror stays cleared.
   ========================================== *)
stHmi.bIsExtended         := bSwitchExtended_eff;
stHmi.bIsRetracted        := bSwitchRetracted_eff;
stHmi.bIsMoving           := bOutSolenoid
                             OR (NOT bSwitchExtended_eff AND NOT bSwitchRetracted_eff);
stHmi.bOutSolenoidExtend  := bOutSolenoid;
stHmi.bOutSolenoidRetract := FALSE;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>