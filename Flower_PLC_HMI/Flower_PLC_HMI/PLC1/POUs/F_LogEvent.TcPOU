<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="F_LogEvent" Id="{1b768838-9216-4ff9-ba10-882311e2c1d0}" SpecialFunc="None">
    <Declaration><![CDATA[(*
    Push one entry into the GVL_Log ring buffer.

    Callable from any scan without side effects on control logic. DEBUG entries
    are dropped when GVL_Log.bDebugMode = FALSE, so leaving DBG calls in
    production code costs nothing.

    Returns TRUE if the entry was recorded, FALSE if dropped by the debug filter.
*)
FUNCTION F_LogEvent : BOOL
VAR_INPUT
    eSev    : E_LogSev;
    sSource : STRING(20);
    sMsg    : STRING(80);
END_VAR
VAR
    idx : UDINT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Debug filter — drop DBG severity when debug mode is off
IF (eSev = E_LogSev.DBG) AND NOT GVL_Log.bDebugMode THEN
    F_LogEvent := FALSE;
    RETURN;
END_IF

// Write into the ring at slot = nWriteIdx MOD 256
idx := GVL_Log.nWriteIdx MOD 256;
GVL_Log.aLog[idx].eSev    := eSev;
GVL_Log.aLog[idx].sSource := sSource;
GVL_Log.aLog[idx].sMsg    := sMsg;

// Increment the monotonic write counter — Python bridge polls this and
// drains any slots between its lastReadIdx and this value.
GVL_Log.nWriteIdx := GVL_Log.nWriteIdx + 1;

F_LogEvent := TRUE;
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
