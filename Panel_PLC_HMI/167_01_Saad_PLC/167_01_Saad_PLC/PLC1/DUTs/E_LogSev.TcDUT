  <DUT Name="E_LogSev" Id="{06c26114-c0db-4bdf-9b2c-1c5d7487b400}">
    <Declaration><![CDATA[{attribute 'qualified_only'}
{attribute 'strict'}
{attribute 'to_string'}
TYPE E_LogSev :
(
