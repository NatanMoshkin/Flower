<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="MAIN" Id="{14abf4a7-7840-47f5-84af-a7dedadf8c83}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
    fbSepSol1  : FB_SolSpringPiston_2Pos;
    fbSepSol2  : FB_SolSpringPiston_2Pos;
    fbSepSol3  : FB_SolSpringPiston_2Pos;
    fbPushSol1 : FB_SolSpringPiston_2Pos;
    fbPushSol2 : FB_SolSpringPiston_2Pos;
    fbPushSol3 : FB_SolSpringPiston_2Pos;

    // Full-machine sequencer coordinating the 3 pairs of (SepSolN,
    // PushSolN) plus the robot handshake. In this panel solution the
    // master cycle is the ONLY auto driver — the per-piston auto tiles
    // (bench-only feature) are removed, so no OR-merge at the call sites.
    fbMasterAutoCycle : FB_MasterAutoCycle;

    // Robot TCP/IP client — parameter/trigger protocol on :6001 (tuning
    // params + New_Bulb). ADDED ALONGSIDE the discrete-I/O start/done
    // handshake (GVL_Robot.stRobot.bStartAssembly / bAssemblyRunning),
    // which stays the safety-critical path. Free Tc2_TcpIp over TF6310.
    fbRobotTcp : FB_RobotTcpClient;

    // Scratch copies of the global machine mode, computed once per scan and
    // fanned out to all six pistons (both eMode and bMode) just below.
    bMachineAuto : BOOL;
    eMachineMode : E_ControlMode;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ==========================================
   Master auto-cycle — coordinates the 3 pairs of (Sep,Push) pistons
   with the robot handshake. Called BEFORE the per-piston
   auto FBs and BEFORE the piston FBs so its bSepCmd* / bPushCmd*
   outputs feed forward this scan.
   Master reads bIs* from the piston stHmi structs — those carry the
   previous scan's values (100 µs lag, negligible for a physical
   machine).
   ========================================== *)
fbMasterAutoCycle.bSepIsExtended[1]   := GVL_HMI.stSepSol1.bIsExtended;
fbMasterAutoCycle.bSepIsExtended[2]   := GVL_HMI.stSepSol2.bIsExtended;
fbMasterAutoCycle.bSepIsExtended[3]   := GVL_HMI.stSepSol3.bIsExtended;
fbMasterAutoCycle.bSepIsRetracted[1]  := GVL_HMI.stSepSol1.bIsRetracted;
fbMasterAutoCycle.bSepIsRetracted[2]  := GVL_HMI.stSepSol2.bIsRetracted;
fbMasterAutoCycle.bSepIsRetracted[3]  := GVL_HMI.stSepSol3.bIsRetracted;
fbMasterAutoCycle.bPushIsExtended[1]  := GVL_HMI.stPushSol1.bIsExtended;
fbMasterAutoCycle.bPushIsExtended[2]  := GVL_HMI.stPushSol2.bIsExtended;
fbMasterAutoCycle.bPushIsExtended[3]  := GVL_HMI.stPushSol3.bIsExtended;
fbMasterAutoCycle.bPushIsRetracted[1] := GVL_HMI.stPushSol1.bIsRetracted;
fbMasterAutoCycle.bPushIsRetracted[2] := GVL_HMI.stPushSol2.bIsRetracted;
fbMasterAutoCycle.bPushIsRetracted[3] := GVL_HMI.stPushSol3.bIsRetracted;
fbMasterAutoCycle(
    bStartAssembly := GVL_Robot.stRobot.bStartAssembly,
    bMachineAuto   := GVL_HmiPersistent.stMasterAutoCfg.bAutoMode,
    stHmi          := GVL_HMI.stMasterAuto,
    stCfg          := GVL_HmiPersistent.stMasterAutoCfg,
    stRobot        := GVL_Robot.stRobot
);

(* Global Auto/Manual hard interlock. The machine-wide bAutoMode is the single
   source of truth for every piston's mode — driven unconditionally each scan
   onto BOTH eMode and bMode so a per-piston toggle cannot create a second
   control path (no double-control). FB_SolSpringPiston_2Pos edge-syncs
   bMode<->eMode, so forcing only one would let a stray toggle propagate for a
   scan; forcing both closes that gap. In Automatic the master cycle owns all
   six pistons; in Manual the operator jogs them and the cycle is held in IDLE. *)
bMachineAuto := GVL_HmiPersistent.stMasterAutoCfg.bAutoMode;
eMachineMode := SEL(bMachineAuto, E_ControlMode.Manual, E_ControlMode.Automatic);
GVL_HMI.stSepSol1.eMode  := eMachineMode;  GVL_HMI.stSepSol1.bMode  := bMachineAuto;
GVL_HMI.stPushSol1.eMode := eMachineMode;  GVL_HMI.stPushSol1.bMode := bMachineAuto;
GVL_HMI.stSepSol2.eMode  := eMachineMode;  GVL_HMI.stSepSol2.bMode  := bMachineAuto;
GVL_HMI.stPushSol2.eMode := eMachineMode;  GVL_HMI.stPushSol2.bMode := bMachineAuto;
GVL_HMI.stSepSol3.eMode  := eMachineMode;  GVL_HMI.stSepSol3.bMode  := bMachineAuto;
GVL_HMI.stPushSol3.eMode := eMachineMode;  GVL_HMI.stPushSol3.bMode := bMachineAuto;

(* ==========================================
   Pin separators (SOL-Spring, 2 limit switches, single Extend coil).
   The master cycle is the only auto driver; in Manual the piston FB
   ignores bAutoCmd* and follows the operator's jog buttons instead.
   ========================================== *)
fbSepSol1(
    bAutoCmdExtend   := fbMasterAutoCycle.bSepCmdExtend[1],
    bAutoCmdRetract  := fbMasterAutoCycle.bSepCmdRetract[1],
    bSwitchExtended  := GVL_App.bSensorSepExtended1,
    bSwitchRetracted := GVL_App.bSensorSepRetracted1,
    stHmi            := GVL_HMI.stSepSol1,
    bOutSolenoid     => GVL_App.bValveSepExtend1
);

fbSepSol2(
    bAutoCmdExtend   := fbMasterAutoCycle.bSepCmdExtend[2],
    bAutoCmdRetract  := fbMasterAutoCycle.bSepCmdRetract[2],
    bSwitchExtended  := GVL_App.bSensorSepExtended2,
    bSwitchRetracted := GVL_App.bSensorSepRetracted2,
    stHmi            := GVL_HMI.stSepSol2,
    bOutSolenoid     => GVL_App.bValveSepExtend2
);

fbSepSol3(
    bAutoCmdExtend   := fbMasterAutoCycle.bSepCmdExtend[3],
    bAutoCmdRetract  := fbMasterAutoCycle.bSepCmdRetract[3],
    bSwitchExtended  := GVL_App.bSensorSepExtended3,
    bSwitchRetracted := GVL_App.bSensorSepRetracted3,
    stHmi            := GVL_HMI.stSepSol3,
    bOutSolenoid     => GVL_App.bValveSepExtend3
);

(* ==========================================
   Pin pushers
   ========================================== *)
fbPushSol1(
    bAutoCmdExtend   := fbMasterAutoCycle.bPushCmdExtend[1],
    bAutoCmdRetract  := fbMasterAutoCycle.bPushCmdRetract[1],
    bSwitchExtended  := GVL_App.bSensorPushExtended1,
    bSwitchRetracted := GVL_App.bSensorPushRetracted1,
    stHmi            := GVL_HMI.stPushSol1,
    bOutSolenoid     => GVL_App.bValvePushExtend1
);

fbPushSol2(
    bAutoCmdExtend   := fbMasterAutoCycle.bPushCmdExtend[2],
    bAutoCmdRetract  := fbMasterAutoCycle.bPushCmdRetract[2],
    bSwitchExtended  := GVL_App.bSensorPushExtended2,
    bSwitchRetracted := GVL_App.bSensorPushRetracted2,
    stHmi            := GVL_HMI.stPushSol2,
    bOutSolenoid     => GVL_App.bValvePushExtend2
);

fbPushSol3(
    bAutoCmdExtend   := fbMasterAutoCycle.bPushCmdExtend[3],
    bAutoCmdRetract  := fbMasterAutoCycle.bPushCmdRetract[3],
    bSwitchExtended  := GVL_App.bSensorPushExtended3,
    bSwitchRetracted := GVL_App.bSensorPushRetracted3,
    stHmi            := GVL_HMI.stPushSol3,
    bOutSolenoid     => GVL_App.bValvePushExtend3
);

(* ==========================================
   Robot TCP/IP client (parameter/trigger protocol, port 6001). Runs every
   scan; its internal state machine dials the robot server and auto-reconnects
   on drop. The safety-critical start/done handshake is discrete I/O elsewhere.
   ========================================== *)
fbRobotTcp(
    bEnable     := GVL_Robot.bTcpEnable,
    sRemoteHost := GVL_Robot.sRobotHost,
    nRemotePort := GVL_Robot.nRobotPort,
    stRobot     := GVL_Robot.stRobot,
    stParams    := GVL_Robot.stParams
);

]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>